<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0a0c0f">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="BES">
<title>BES Portföyü</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0c0f;--card:#161a1f;--border:#1e2530;--accent:#a78bfa;--green:#00ff88;--red:#ff3860;--text:#e0e8f0;--muted:#5a6a7a}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;padding-bottom:40px}
header{background:#0d1117;border-bottom:1px solid var(--accent);padding:14px 16px}
.h-title{font-size:22px;font-weight:700;letter-spacing:2px;background:linear-gradient(90deg,var(--accent),var(--green));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.h-sub{font-size:11px;color:var(--muted);font-family:'Share Tech Mono',monospace;margin-top:2px}
.total-card{margin:16px;background:var(--card);border:1px solid var(--accent);border-radius:16px;padding:20px;text-align:center}
.total-label{font-size:11px;color:var(--muted);letter-spacing:2px;text-transform:uppercase}
.total-val{font-family:'Share Tech Mono',monospace;font-size:36px;font-weight:700;color:var(--accent);margin:8px 0}
.total-change{font-size:14px;font-family:'Share Tech Mono',monospace}
.input-card{margin:0 16px 16px;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px}
.inp-label{font-size:11px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;display:block;margin-bottom:8px}
.inp{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Share Tech Mono',monospace;font-size:28px;padding:12px;outline:none;-webkit-appearance:none;text-align:center}
.inp:focus{border-color:var(--accent)}
.btn{width:100%;padding:14px;border-radius:10px;border:none;background:linear-gradient(135deg,var(--accent),#7c3aed);color:#fff;font-family:'Rajdhani',sans-serif;font-size:16px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;margin-top:10px}
.stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin:0 16px 16px}
.stat{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px;text-align:center}
.stat-l{font-size:9px;color:var(--muted);letter-spacing:1px;text-transform:uppercase}
.stat-v{font-family:'Share Tech Mono',monospace;font-size:15px;margin-top:3px}
.pos{color:var(--green)}.neg{color:var(--red)}.neu{color:var(--muted)}
.sec-title{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin:0 16px 8px}
.hist-card{margin:0 16px;background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.hist-row{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-bottom:1px solid rgba(255,255,255,.04)}
.hist-row:last-child{border-bottom:none}
.hist-date{font-size:12px;color:var(--muted)}
.hist-val{font-family:'Share Tech Mono',monospace;font-size:15px;color:var(--accent)}
.hist-ch{font-size:12px;font-family:'Share Tech Mono',monospace}
.del-btn{background:rgba(255,56,96,.1);border:1px solid var(--red);color:var(--red);border-radius:6px;padding:3px 8px;font-size:11px;cursor:pointer;font-family:'Rajdhani',sans-serif}
#alert{position:fixed;bottom:20px;left:16px;right:16px;z-index:999;padding:12px 16px;border-radius:10px;font-size:14px;font-weight:700;display:none;align-items:center;justify-content:center}
#alert.ok{background:var(--green);color:#000}
#alert.err{background:var(--red);color:#fff}
</style>
</head>
<body>
<header>
  <div class="h-title">BES PORTFÖYÜ</div>
  <div class="h-sub" id="last-update">Son giriş: —</div>
</header>

<div class="total-card">
  <div class="total-label">Güncel Değer</div>
  <div class="total-val" id="total-val">—</div>
  <div class="total-change" id="total-change"></div>
</div>

<div class="input-card">
  <label class="inp-label">YENİ DEĞER GİR (₺)</label>
  <input class="inp" type="number" inputmode="decimal" step="0.01" placeholder="0.00" id="bes-inp">
  <button class="btn" onclick="saveEntry()">💾 KAYDET</button>
</div>

<div class="stats">
  <div class="stat"><div class="stat-l">Haftalık</div><div class="stat-v neu" id="s-weekly">—</div></div>
  <div class="stat"><div class="stat-l">Aylık</div><div class="stat-v neu" id="s-monthly">—</div></div>
  <div class="stat"><div class="stat-l">Toplam</div><div class="stat-v neu" id="s-total">—</div></div>
</div>

<div class="sec-title">GEÇMİŞ</div>
<div class="hist-card" id="hist-list">
  <div style="text-align:center;color:var(--muted);padding:24px;font-size:13px">Henüz giriş yok</div>
</div>

<div id="alert"><span id="alert-text"></span></div>

<script>
var entries=[];
window.onload=function(){load();render();};

function fmtTL(n){return n.toLocaleString('tr-TR',{minimumFractionDigits:2,maximumFractionDigits:2});}

function saveEntry(){
  var v=parseFloat(document.getElementById('bes-inp').value);
  if(isNaN(v)||v<=0){showAlert('err','Geçerli bir değer girin!');return;}
  entries.push({date:new Date().toISOString(),value:v});
  document.getElementById('bes-inp').value='';
  save();render();
  showAlert('ok','₺'+fmtTL(v)+' kaydedildi!');
}

function deleteEntry(i){
  entries.splice(i,1);
  save();render();
}

function render(){
  if(entries.length===0){
    document.getElementById('total-val').textContent='—';
    document.getElementById('total-change').textContent='';
    document.getElementById('last-update').textContent='Son giriş: —';
    document.getElementById('s-weekly').textContent='—';
    document.getElementById('s-monthly').textContent='—';
    document.getElementById('s-total').textContent='—';
    document.getElementById('hist-list').innerHTML='<div style="text-align:center;color:var(--muted);padding:24px;font-size:13px">Henüz giriş yok</div>';
    return;
  }
  var cur=entries[entries.length-1].value;
  var first=entries[0].value;
  document.getElementById('total-val').textContent='₺'+fmtTL(cur);
  document.getElementById('last-update').textContent='Son: '+new Date(entries[entries.length-1].date).toLocaleDateString('tr-TR');

  if(entries.length>=2){
    var prev=entries[entries.length-2].value;
    var ch=(cur-prev)/prev*100;
    var el=document.getElementById('total-change');
    el.textContent=(ch>=0?'▲ +':'▼ ')+ch.toFixed(2)+'%';
    el.className='total-change '+(ch>=0?'pos':'neg');
  }

  var now=new Date();
  var week=new Date(now);week.setDate(week.getDate()-7);
  var month=new Date(now);month.setDate(month.getDate()-30);
  var wE=null,mE=null;
  for(var i=0;i<entries.length;i++){
    if(new Date(entries[i].date)<=week)wE=entries[i];
    if(new Date(entries[i].date)<=month)mE=entries[i];
  }
  setPct('s-weekly',cur,wE?wE.value:null);
  setPct('s-monthly',cur,mE?mE.value:null);
  setPct('s-total',cur,first);

  var html='';
  for(var j=entries.length-1;j>=0;j--){
    var e=entries[j];
    var prev2=j>0?entries[j-1]:null;
    var chStr='';
    if(prev2){var c2=(e.value-prev2.value)/prev2.value*100;chStr='<span class="hist-ch '+(c2>=0?'pos':'neg')+'">'+(c2>=0?'+':'')+c2.toFixed(2)+'%</span>';}
    var d=new Date(e.date);
    html+='<div class="hist-row"><div><div class="hist-val">₺'+fmtTL(e.value)+'</div><div class="hist-date">'+d.toLocaleDateString('tr-TR')+' '+d.toLocaleTimeString('tr-TR',{hour:'2-digit',minute:'2-digit'})+'</div></div><div style="display:flex;align-items:center;gap:10px">'+chStr+'<button class="del-btn" onclick="deleteEntry('+j+')">Sil</button></div></div>';
  }
  document.getElementById('hist-list').innerHTML=html;
}

function setPct(id,cur,prev){
  var el=document.getElementById(id);
  if(!prev){el.textContent='—';el.className='stat-v neu';return;}
  var p=(cur-prev)/prev*100;
  el.textContent=(p>=0?'+':'')+p.toFixed(2)+'%';
  el.className='stat-v '+(p>=0?'pos':'neg');
}

function save(){
  try{
    var d=JSON.stringify({entries:entries});
    try{localStorage.setItem('bes_portfoy',d);}catch(e){}
    try{sessionStorage.setItem('bes_portfoy',d);}catch(e){}
    try{var enc=btoa(unescape(encodeURIComponent(d)));document.cookie='bes_portfoy='+enc+';path=/;max-age=31536000;SameSite=Strict';}catch(e){}
  }catch(e){}
}
function load(){
  try{
    var raw=null;
    try{raw=localStorage.getItem('bes_portfoy');}catch(e){}
    if(!raw){try{raw=sessionStorage.getItem('bes_portfoy');}catch(e){}}
    if(!raw){try{var m=document.cookie.match(/bes_portfoy=([^;]+)/);if(m)raw=decodeURIComponent(escape(atob(m[1])));}catch(e){}}
    if(!raw)return;
    var s=JSON.parse(raw);
    entries=s.entries||[];
  }catch(e){}
}

function showAlert(type,msg){
  var el=document.getElementById('alert');
  document.getElementById('alert-text').textContent=msg;
  el.className=type;el.style.display='flex';
  setTimeout(function(){el.style.display='none';},3000);
}
</script>
</body>
</html>
